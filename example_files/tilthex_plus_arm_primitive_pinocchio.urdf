  <!-- Plugins -->
  <plugin name="mrsim" filename="mrsim-gazebo.so">
    <link>base</link>
    <rotors>
      <noise>0.01</noise>
      <cf>13.0e-4</cf>
      <ct>1.996e-5</ct>
      <vfxy>0.5</vfxy>
      <vfz>0.4</vfz>
      <vtxy>0.2</vtxy>
      <vtz>0.2</vtz>
      <rotor>
        <joint spin="cw">motor-1</joint>
      </rotor>
      <rotor>
        <joint spin="ccw">motor-2</joint>
      </rotor>
      <rotor>
        <joint spin="cw">motor-3</joint>
      </rotor>
      <rotor>
        <joint spin="ccw">motor-4</joint>
      </rotor>
      <rotor>
        <joint spin="cw">motor-5</joint>
      </rotor>
      <rotor>
        <joint spin="ccw">motor-6</joint>
      </rotor>
    </rotors>
  </plugin>

  <!-- Gazebo -->
  <gazebo reference="arm_base">
    <material>Gazebo/Black</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="link1">
    <material>Gazebo/Black</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="link2">
    <material>Gazebo/Green</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="link3">
    <material>Gazebo/Black</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="link4">
    <material>Gazebo/Green</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo reference="markers">
    <material>Gazebo/Black</material>
    <selfCollide>true</selfCollide>
  </gazebo>
  <gazebo>
    <plugin name="arm_plugin" filename="dxsim-gazebo.so">
      <pty>/tmp/pty-boomslang</pty>
      <motors>
        <motor>
          <joint spin="ccw">joint1</joint>
          <p0>0.0</p0>
          <id>1</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
        <motor>
          <joint spin="ccw">joint2</joint>
          <p0>0.0</p0>
          <id>2</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
        <motor>
          <joint spin="ccw">joint3</joint>
          <p0>0.0</p0>
          <id>3</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
        <motor>
          <joint spin="ccw">joint4</joint>
          <p0>0.0</p0>
          <id>4</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
      </motors>
    </plugin>
