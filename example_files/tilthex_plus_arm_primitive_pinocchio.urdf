<?xml version="1.0" ?>

<robot name="tilthex">
  <link name="base">
    <inertial>
      <mass value="2.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0115" ixy="0" ixz="0" iyy="0.0114" iyz="0" izz="0.0194"/>
    </inertial>
    <collision name="base">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1354" length="0.05"/>
      </geometry>
    </collision>
    <!-- three spheres to make contact stable -->
    <collision name="land_1">
      <origin xyz="0.2 0 -0.21" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <collision name="land_2">
      <origin xyz="-0.1 0.173 -0.21" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <collision name="land_3">
      <origin xyz="-0.1 -0.173 -0.21" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <visual name="body">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1354" length="0.05"/>
      </geometry>
      <material name="sky-blue">
        <color rgba="0.4 0.6 1.0 1"/>
      </material>
    </visual>
    <visual name="lander-1">
      <origin xyz="0.1025 0.1776 -0.11" rpy="3.1416 -0.1736 1.0472"/>
      <geometry>
        <cylinder radius="0.01" length="0.25"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <visual name="lander-2">
      <origin xyz="-0.1025 0.1776 -0.11" rpy="3.1416 -0.1736 2.0944"/>
      <geometry>
        <cylinder radius="0.01" length="0.25"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <visual name="lander-3">
      <origin xyz="-0.1025 -0.1776 -0.11" rpy="3.1416 0.1736 1.0472"/>
      <geometry>
        <cylinder radius="0.01" length="0.25"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <visual name="lander-4">
      <origin xyz="0.1025 -0.1776 -0.11" rpy="3.1416 0.1736 2.0944"/>
      <geometry>
        <cylinder radius="0.01" length="0.25"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <visual name="arm-1">
      <origin xyz="0.2150 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.38998"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.2 0.2 1.0"/>
      </material>
    </visual>
    <visual name="arm-2">
      <origin xyz="0.1025 0.1776 0" rpy="0 1.5708 1.0472"/>
      <geometry>
        <cylinder radius="0.01" length="0.40998"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <visual name="arm-3">
      <origin xyz="-0.1025 0.1776 0" rpy="0 1.5708 2.0944"/>
      <geometry>
        <cylinder radius="0.01" length="0.40998"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <visual name="arm-4">
      <origin xyz="-0.2150 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.38998"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <visual name="arm-5">
      <origin xyz="-0.1025 -0.1776 0" rpy="0 1.5708 -2.0944"/>
      <geometry>
        <cylinder radius="0.01" length="0.40998"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <visual name="arm-6">
      <origin xyz="0.1025 -0.1776 0" rpy="0 1.5708 -1.0472"/>
      <geometry>
        <cylinder radius="0.01" length="0.40998"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
  </link>

  <!-- joints -->
  <joint name="base_rotor_1_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-1"/>
    <origin xyz="0.38998 0 0" rpy="-0.349066 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="base_rotor_2_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-2"/>
    <origin xyz="0.195 0.3377 0" rpy="0.349066 0 1.0472"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="base_rotor_3_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-3"/>
    <origin xyz="-0.195 0.3377 0" rpy="-0.349066 0 2.0944"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="base_rotor_4_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-4"/>
    <origin xyz="-0.38998 0 0" rpy="-0.349066 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="base_rotor_5_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-5"/>
    <origin xyz="-0.195 -0.3377 0" rpy="0.349066 0 1.0472"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="base_rotor_6_joint" type="fixed">
    <parent link="base"/>
    <child link="rotor-6"/>
    <origin xyz="0.195 -0.3377 0" rpy="-0.349066 0 2.0944"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="fixed" type="fixed">
    <parent link="base"/>
    <child link="arm_base"/>
    <origin xyz="0 0 -0.025" rpy="3.1415 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="joint1" type="revolute">
    <parent link="arm_base"/>
    <child link="link1"/>
    <origin xyz="0.0 0.0 0.054" rpy="0.0 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-100" upper="100" velocity="5.0"/>
    <dynamics damping="5.3e-6" friction="0.2"/>
  </joint>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.0 0.0 0.167" rpy="1.5707 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-6.283" upper="6.283" velocity="5.0"/>
    <dynamics damping="4.2e-6" friction="0.11"/>
  </joint>
  <!--  Use only two first links 
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.3 0.0 0.0" rpy="0.0 1.5707 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-100" upper="100" velocity="5.0"/>
    <dynamics damping="8e-6" friction="0.15"/>
  </joint>
  
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0 0.0 0.330" rpy="0.0 -1.5707 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="-100" upper="100" velocity="5.0"/>
    <dynamics damping="4.2e-6" friction="0.11"/>
  </joint>
  -->
  <joint name="fixed_markers" type="fixed">
    <parent link="link2"/>
    <child link="markers"/>
    <origin xyz="0.32 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>
  

