    <plugin name='dxsim' filename='dxsim-gazebo.so'>
      <pty>/tmp/pty-boomslang</pty>
      <motors>
        <motor>
          <joint spin='ccw'>joint1</joint>
          <p0>0.0</p0>
          <id>1</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
        <motor>
          <joint spin='ccw'>joint2</joint>
          <p0>0.0</p0>
          <id>2</id>
          <noise>0.001</noise>
