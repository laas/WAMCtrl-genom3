          <p0>0.0</p0>
          <id>4</id>
          <noise>0.001</noise>
          <debug>0</debug>
        </motor>
      </motors>
    </plugin>

    <!-- Attention! SDF converter merged link "link 4" and link "markers"
    <frame name='fixed_markers' attached_to='link4'>
      <pose>0.074999999999999997 0 0 0 0 0</pose>
    </frame>
    <frame name='markers' attached_to='fixed_markers'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    -->

    <plugin name="mrsim" filename="mrsim-gazebo.so">
      <link>base</link>

      <rotors>
        <noise>0.01</noise>
        <cf>13.0e-4</cf>
        <ct>1.996e-5</ct>
        <vfxy>0.5</vfxy><vfz>0.4</vfz>
        <vtxy>0.2</vtxy><vtz>0.2</vtz>

        <rotor><joint spin="cw">motor-1</joint></rotor>
        <rotor><joint spin="ccw">motor-2</joint></rotor>
        <rotor><joint spin="cw">motor-3</joint></rotor>
        <rotor><joint spin="ccw">motor-4</joint></rotor>
        <rotor><joint spin="cw">motor-5</joint></rotor>
        <rotor><joint spin="ccw">motor-6</joint></rotor>
      </rotors>
    </plugin>
</model>
